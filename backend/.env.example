# MongoDB connection string
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster-url>/<db_name>?retryWrites=true&w=majority

# GROQ AI API key (for chatbot)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Indian helpline (default is pre-set to iCall + Vandrevala)
# Uncomment to override:
# HELPLINE_NUMBER=iCall: 9152987821 | Vandrevala Foundation: 1860-2662-345

# Email configuration (for signup verification & password reset)
# Use Gmail App Password (not your regular password)
# Go to Google Account > Security > 2-Step Verification > App Passwords
#EMAIL_SERVICE=gmail
#EMAIL_USER=your_gmail@gmail.com
#EMAIL_PASS=your_16_char_app_password

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5000

# Admin secret key (for looking up anonymous user identities)
ADMIN_KEY=change_this_to_a_long_secret_string

# Server port
PORT=5000