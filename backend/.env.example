# MongoDB connection string
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster-url>/<db_name>?retryWrites=true&w=majority

# GROQ AI API key (for chatbot)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Indian helpline (default is pre-set to iCall + Vandrevala)
# HELPLINE_NUMBER=iCall: 9152987821 | Vandrevala Foundation: 1860-2662-345

# Email configuration (for signup verification & password reset)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_gmail@gmail.com
# EMAIL_PASS=your_16_char_app_password

# Frontend URL (used in email links and CORS)
FRONTEND_URL=http://localhost:5000

# Fix #9: Comma-separated list of allowed frontend origins (CORS)
# In production set this to your actual domain, e.g. https://eudyaan.com
ALLOWED_ORIGINS=http://localhost:5000

# Fix #1: Admin password stored as bcrypt hash (NEVER store plaintext)
# To generate your hash, run:  node scripts/hash-admin-password.js yourpassword
ADMIN_EMAIL=admin@eudyaan.local
ADMIN_PASSWORD_HASH=$2b$12$examplehashgoeshere...

# Fix #4: Secret for HMAC-based anonymous IDs (set a long random string)
# To generate: node -e "require('crypto').randomBytes(32).toString('hex').then ? '' : console.log(require('crypto').randomBytes(32).toString('hex'))"
ANON_ID_SECRET=change_this_to_a_long_random_secret_string

# Server port
PORT=5000
